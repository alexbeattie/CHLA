# Root Django/backend environment variables.
# Copy to `.env.local` (development) or `.env.production` and fill in values.
# Never commit real credentials.

# --- Django ---
DJANGO_SETTINGS_MODULE=maplocation.settings
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# --- Database (Postgres / RDS) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maplocation
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSL_REQUIRE=False

# --- Allowed hosts / CORS / CSRF (production-only; comma-separated) ---
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
