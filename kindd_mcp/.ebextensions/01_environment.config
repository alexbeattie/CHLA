option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8800"
    KINDD_API_BASE_URL: "https://api.kinddhelp.com/api"
    AWS_REGION: "us-west-2"
    # KINDD_MCP_AUTH_TOKEN is intentionally not set here. Either set it
    # directly as an environment property (eb setenv) or leave it unset so
    # docker-entrypoint.sh fetches it from AWS Secrets Manager
    # (kindd/prod/mcp-auth-token). Never commit the token value itself.
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: "/health"
  aws:elbv2:loadbalancer:
    # Streamable HTTP keeps a connection open per in-flight tool call;
    # the ALB default of 60s is too short for slower provider searches.
    IdleTimeout: "300"
