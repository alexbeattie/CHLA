# Base URL of the public KiNDD REST API this MCP server calls.
# Production:
KINDD_API_BASE_URL=https://api.kinddhelp.com/api
# Local development against ./maplocation:
# KINDD_API_BASE_URL=http://127.0.0.1:8000/api

# Host/port for the standalone Streamable HTTP MCP server.
KINDD_MCP_HOST=0.0.0.0
KINDD_MCP_PORT=8800

# Shared-secret bearer token clients must send as `Authorization: Bearer <token>`.
# Leave unset for local development (server runs unauthenticated). REQUIRED for
# any deployment reachable outside localhost. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
KINDD_MCP_AUTH_TOKEN=
