option_settings:
  aws:elasticbeanstalk:application:environment:
    ALLOWED_HOSTS: "*"
    AWS_REGION: "us-west-2"
    CSRF_TRUSTED_ORIGINS: "https://api.kinddhelp.com,https://kinddhelp.com,https://www.kinddhelp.com"
    DB_SSL_REQUIRE: "true"
    DJANGO_DEBUG: "false"
    DJANGO_SETTINGS_MODULE: "maplocation.settings"
    # DB_HOST/PORT/NAME/USER/PASSWORD and DJANGO_SECRET_KEY are populated at
    # container startup by docker-entrypoint.sh from AWS Secrets Manager
    # (kindd/prod/rds and kindd/prod/django-secret-key). Do not put secrets here.
