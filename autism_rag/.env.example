# ----------------------------------------------------------------------------
# Autism Research RAG - environment template
#
# Copy this file to autism_rag/.env and fill in the values below. The .env
# file is gitignored. Never put real API keys in this .env.example file.
#
#   cp autism_rag/.env.example autism_rag/.env
#
# Required for any real run: COHERE_API_KEY, PINECONE_API_KEY.
# Optional but recommended: NCBI_EMAIL, NCBI_API_KEY, OPENAI_API_KEY,
# FIRECRAWL_API_KEY.
# ----------------------------------------------------------------------------

# === Cohere ==================================================================
# Used for embeddings (embed-v4.0) and optional rerank.
# Get a key at https://dashboard.cohere.com/api-keys
# Required.
COHERE_API_KEY=

# Embedding model + dimension. embed-v4.0 supports 256, 512, 1024, 1536.
COHERE_EMBED_MODEL=embed-v4.0
COHERE_EMBED_DIM=1536

# Reranker (optional, applied after Pinecone retrieval).
RERANK_ENABLED=true
RERANK_MODEL=rerank-english-v3.0

# === Pinecone ================================================================
# Serverless vector store. Index is auto-created on first ingestion.
# Get a key at https://app.pinecone.io/
# Required.
PINECONE_API_KEY=

# Index name in your Pinecone project. Anything safe for DNS; lowercase.
PINECONE_INDEX=autism-research-rag

# Serverless target. Match a region your Pinecone project supports.
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Distance metric for the dense index. Cohere embed-v4.0 plays well with cosine.
PINECONE_METRIC=cosine

# Must equal COHERE_EMBED_DIM above.
PINECONE_EMBED_DIMS=1536

# === Firecrawl ===============================================================
# Used only for explicitly permitted web pages. Bulk crawling is intentionally
# not supported; see autism_rag/sources/adapters/firecrawl_web.py.
# Get a key at https://www.firecrawl.dev/app/api-keys
# Optional. Leave empty to disable web ingestion.
FIRECRAWL_API_KEY=

# === NCBI E-utilities (PubMed / PMC) =========================================
# An email + API key bumps rate limits from 3/sec to 10/sec and is required
# by NCBI for any non-trivial automated use.
# Register a key at https://www.ncbi.nlm.nih.gov/account/settings/
# Optional, but strongly recommended.
NCBI_API_KEY=
NCBI_TOOL=autism_research_rag
NCBI_EMAIL=

# === OpenAI (answer generation) ==============================================
# When set, the Answerer uses this model for citation-grounded answers.
# When empty, the Answerer falls back to deterministic extractive snippets so
# retrieval can still be inspected end-to-end.
# Get a key at https://platform.openai.com/api-keys
# Optional.
OPENAI_API_KEY=
ANSWER_MODEL=gpt-4o-mini

# === Retrieval defaults ======================================================
# How many chunks the API/CLI return per query before answer generation.
DEFAULT_TOP_K=8
