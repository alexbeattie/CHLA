# Frontend environment variables.
# Copy to `.env`, `.env.development`, `.env.production`, or `.env.test` and fill in values.
# Never commit real tokens or API keys.

# Mapbox public token (pk.*) — required for map rendering.
# Code also reads VITE_MAPBOX_ACCESS_TOKEN and VITE_MAPBOX_API_TOKEN as legacy aliases.
VITE_MAPBOX_TOKEN=pk.replace_me

# Backend API base URL.
# Canonical name is VITE_API_BASE_URL. Some code paths still read VITE_API_URL as a fallback.
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Optional: Google Analytics measurement ID.
VITE_GA_MEASUREMENT_ID=

# Optional: Vite dev server port override (default 3000).
VITE_PORT=3000
