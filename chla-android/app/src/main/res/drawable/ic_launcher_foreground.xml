<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Adaptive-icon layers are 108dp with a centered 72dp masked viewport.
      Insetting the complete iPhone artwork by 18dp preserves its exact
      proportions while Android applies the device's launcher mask.
    -->
    <item
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp"
        android:top="18dp">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/kindd_app_icon" />
    </item>
</layer-list>
